# ------------------------------------------------------------------
# Production env. Copy to .env.production (manual VPS) OR paste into the
# Hostinger "Environment variables" field (managed deploy).
#   cp .env.production.example .env.production
# NEVER commit .env.production (it is gitignored via .env.*).
# ------------------------------------------------------------------

# --- Postgres (used to build DATABASE_URL inside compose) ---
POSTGRES_USER=sindicato
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=sindicato_rural_tr

# --- Auth: must be >= 32 chars. Generate: openssl rand -hex 32 ---
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32_to_generate

# --- CORS: your frontend origin(s), comma-separated. Avoid "*" in prod. ---
CORS_ORIGIN=https://seu-frontend.com

# --- Storage buckets (must exist in Supabase, set to PUBLIC) ---
STORAGE_BUCKET=avatars
BANNER_BUCKET=course-banners

# --- Supabase S3-compatible storage ---
# Dashboard → Project Settings → Storage → S3 connection.
# Region, endpoint and access keys are all shown there.
AWS_REGION=CHANGE_ME_supabase_region            # e.g. sa-east-1 (must match dashboard)
AWS_ACCESS_KEY_ID=CHANGE_ME_supabase_s3_key_id
AWS_SECRET_ACCESS_KEY=CHANGE_ME_supabase_s3_secret
S3_ENDPOINT=https://nmzyqzzaozwpkmmsdvuu.storage.supabase.co/storage/v1/s3
S3_PUBLIC_URL=https://nmzyqzzaozwpkmmsdvuu.supabase.co/storage/v1/object/public
