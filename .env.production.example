# ------------------------------------------------------------------
# Production env for VPS. Copy to .env.production and fill real values.
#   cp .env.production.example .env.production
# NEVER commit .env.production (it is gitignored via .env.*).
# ------------------------------------------------------------------

# --- Postgres (used to build DATABASE_URL inside compose) ---
POSTGRES_USER=sindicato
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=sindicato_rural_tr

# --- Auth: must be >= 32 chars. Generate: openssl rand -hex 32 ---
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32_to_generate

# --- CORS: your frontend origin(s), comma-separated. Avoid "*" in prod. ---
CORS_ORIGIN=https://seu-frontend.com

# --- Storage buckets ---
STORAGE_BUCKET=avatars
BANNER_BUCKET=course-banners

# --- MinIO credentials ---
MINIO_ACCESS_KEY=CHANGE_ME_minio_user
MINIO_SECRET_KEY=CHANGE_ME_strong_minio_password

# --- MinIO PUBLIC endpoint ---
# Browsers fetch uploaded files from this URL, so it MUST be reachable from outside.
# IP-based (quick start):      http://SEU_IP_DA_VPS:9000
# Domain + TLS (recommended):  https://storage.seu-dominio.com
MINIO_ENDPOINT=http://SEU_IP_DA_VPS:9000

# --- Grafana admin (console at localhost:3001 via SSH tunnel) ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password
