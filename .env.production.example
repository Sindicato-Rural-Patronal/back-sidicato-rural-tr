# ------------------------------------------------------------------
# Production env. Copy to .env.production (manual VPS) OR paste into the
# Hostinger "Environment variables" field (managed deploy).
#   cp .env.production.example .env.production
# NEVER commit .env.production (it is gitignored via .env.*).
# ------------------------------------------------------------------

# --- Database: external Supabase Postgres ---
# Dashboard → "Connect" → "Session pooler" (IPv4, port 5432).
# Do NOT use the Direct connection (db.<ref>.supabase.co) — it is IPv6-only and
# unreachable from Docker/most hosts. Session pooler supports migrations.
# Username becomes postgres.<project-ref> and host is aws-0-<region>.pooler.supabase.com
DATABASE_URL=postgresql://postgres.nmzyqzzaozwpkmmsdvuu:CHANGE_ME@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Auth: must be >= 32 chars. Generate: openssl rand -hex 32 ---
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32_to_generate

# --- CORS: your frontend origin(s), comma-separated. Avoid "*" in prod. ---
CORS_ORIGIN=https://seu-frontend.com

# --- Supabase Storage ---
# Dashboard → Project Settings → API Keys.
#   SUPABASE_URL        = Project URL (https://<ref>.supabase.co)
#   SUPABASE_SECRET_KEY = secret key (sb_secret_... — server-side only, NOT the publishable key)
# Create these buckets in Supabase and mark them PUBLIC: avatars, course-banners, news-banners
SUPABASE_URL=https://nmzyqzzaozwpkmmsdvuu.supabase.co
SUPABASE_SECRET_KEY=sb_secret_CHANGE_ME
