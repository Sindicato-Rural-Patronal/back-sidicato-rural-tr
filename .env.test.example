# E2E test environment — copy to .env.test and fill in values
# WARNING: DATABASE_TEST_URL must point to a SEPARATE test database.
# The globalSetup wipes it completely before every test run.

DATABASE_TEST_URL=postgresql://user:password@localhost:5432/sindicato_test

# JWT_SECRET is hardcoded in vitest.config.e2e.ts for tests — do not set here
# STORAGE_TYPE defaults to minio in tests; uploads are not tested (no MinIO required)
