# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sindicato_rural_tr_dev?schema=public"

# Auth — mínimo 32 caracteres
JWT_SECRET="your_secret_key_minimum_32_characters_long"

# Server
PORT=3000
NODE_ENV=development

# Storage: minio (dev) ou s3 (prod)
STORAGE_TYPE=minio
STORAGE_BUCKET=avatars
BANNER_BUCKET=course-banners

# MinIO (desenvolvimento)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# AWS S3 (produção — preencher se STORAGE_TYPE=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
