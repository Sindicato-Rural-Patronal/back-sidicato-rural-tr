# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sindicato_rural_tr_dev?schema=public"

# Auth — mínimo 32 caracteres
JWT_SECRET="your_secret_key_minimum_32_characters_long"

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Supabase Storage
# Dashboard → Project Settings → API Keys: Project URL + secret key (sb_secret_...).
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_key

# Bucket names (must exist in Supabase and be PUBLIC)
STORAGE_BUCKET=avatars
BANNER_BUCKET=course-banners
NEWS_BANNER_BUCKET=news-banners
