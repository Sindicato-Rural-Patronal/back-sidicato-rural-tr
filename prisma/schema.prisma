// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

model UserAdmin {
  id           String @id @default(uuid())
  username     String @unique
  passwordHash String

  isPublic    Boolean @default(false)
  publicTitle String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userData   UserData @relation(fields: [userDataId], references: [id])
  userDataId String   @unique

  rules   Rule   @relation(fields: [rulesId], references: [id])
  rulesId String
}

model UserData {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String   @unique
  avatar    String?
  cpf       String?
  cnpj      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identity
  nickname         String?
  maritalStatus    MaritalStatus?
  phone2           String?
  phone3           String?

  // Documents
  rg               String?
  rgIssuer         String?
  rgIssuedAt       DateTime?
  birthDate        DateTime?
  driverLicense    String?
  driverLicenseCategory String?

  // Origin
  birthPlace       String?
  nationality      String?

  // Profile
  gender           Gender?
  ethnicity        Ethnicity?
  educationLevel   EducationLevel?
  functionalCategory String?
  specialNeeds     Boolean        @default(false)

  // Membership
  memberClassification String?
  cadPro           String?
  familyIncome     String?
  memberType       String?
  boardPosition    String?
  boardMember      Boolean        @default(false)
  memberStatus     MemberStatus?
  memberSince      DateTime?
  memberNotes      String?
  memberNotesNumber String?

  // Partner (corporate members shown publicly)
  isPartner    Boolean @default(false)
  partnerUrl   String?
  partnerLogo  String?
  partnerOrder Int?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  courseUserRegistration courseUserRegistration[]
  userAdmin              UserAdmin?

  userInstructor UserInstructor?

  // Relations to other UserData
  relations        UserRelation[] @relation("RelationSource")
  relatedBy        UserRelation[] @relation("RelationTarget")

  // Properties owned
  properties       Property[]
}

model UserInstructor {
  id         String   @id @default(uuid())
  bio        String?
  linkedin   String?
  instagram  String?
  facebook   String?
  userData   UserData @relation(fields: [userDataId], references: [id])
  userDataId String   @unique

  courseAssignments CourseInstructor[]
}

model CourseInstructor {
  id           String   @id @default(uuid())
  title        String?
  category     String?
  instructor   UserInstructor @relation(fields: [instructorId], references: [id])
  instructorId String
  course       course   @relation(fields: [courseId], references: [id])
  courseId     String
  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())

  @@unique([instructorId, courseId])
}

model Rule {
  id          String @id @default(uuid())
  name        String
  description String

  permissions Permission[]

  userAdmin UserAdmin[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model course {
  id          String   @id @default(uuid())
  name        String
  description String
  startTime   DateTime
  endTime     DateTime

  status               CourseStatus @default(UNPUBLISHED)
  bannerUrl            String?
  price                Float        @default(0)
  workloadHours        Int          @default(0)
  registrationDeadline DateTime?
  observations         String?
  eventNumber          String?
  minStudents          Int          @default(0)
  preEnrolled          Int          @default(0)
  waitlist             Int          @default(0)

  room    room   @relation(fields: [roomId], references: [id])
  roomId  String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  photos                 CoursePhoto[]
  courseUserRegistration courseUserRegistration[]
  instructors            CourseInstructor[]
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model CoursePhoto {
  id        String   @id @default(uuid())
  url       String
  caption   String?
  course    course   @relation(fields: [courseId], references: [id])
  courseId  String
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
}

model room {
  id          String   @id @default(uuid())
  name        String
  description String
  maxCapacity Int
  courses     course[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  addressId  String?
  address    Address? @relation(fields: [addressId], references: [id])
}

model News {
  id          String     @id @default(uuid())
  title       String
  content     String
  summary     String?
  bannerUrl   String?
  status      NewsStatus @default(UNPUBLISHED)
  publishedAt DateTime?
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model courseUserRegistration {
  id         String   @id @default(uuid())
  course     course   @relation(fields: [courseId], references: [id])
  courseId   String
  userData   UserData @relation(fields: [userDataId], references: [id])
  userDataId String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CourseStatus {
  PUBLIC
  PRIVATE
  UNPUBLISHED
}

enum NewsStatus {
  PUBLISHED
  UNPUBLISHED
}

enum Permission {
  CREATE_USER
  UPDATE_USER
  DELETE_USER
  READ_USER

  CREATE_COURSE
  UPDATE_COURSE
  DELETE_COURSE
  READ_COURSE

  CREATE_RULE
  UPDATE_RULE
  DELETE_RULE
  READ_RULE

  CREATE_USER_ADMIN
  UPDATE_USER_ADMIN
  DELETE_USER_ADMIN
  READ_USER_ADMIN

  CREATE_NEWS
  UPDATE_NEWS
  DELETE_NEWS
  READ_NEWS

  READ_CONTACT
  UPDATE_CONTACT

  CREATE_BANNER
  UPDATE_BANNER
  DELETE_BANNER
  READ_BANNER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  DOMESTIC_PARTNERSHIP
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Ethnicity {
  WHITE
  BLACK
  MIXED
  ASIAN
  INDIGENOUS
}

enum EducationLevel {
  NO_FORMAL_EDUCATION
  INCOMPLETE_PRIMARY
  COMPLETE_PRIMARY
  INCOMPLETE_SECONDARY
  COMPLETE_SECONDARY
  INCOMPLETE_HIGHER
  COMPLETE_HIGHER
  POSTGRADUATE
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum AddressType {
  URBAN
  RURAL
}

model Address {
  id          String      @id @default(uuid())
  type        AddressType @default(URBAN)

  // Shared
  city        String?
  state       String?
  zipCode     String?
  complement  String?
  notes       String?

  // Urban
  street      String?
  number      String?
  neighborhood String?

  // Rural
  localityName String?
  road         String?
  km           String?
  lot          String?
  section      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties   Property[]
  rooms        room[]
}

model Property {
  id            String    @id @default(uuid())
  userDataId    String
  name          String
  registration  String?
  addressId     String
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userData  UserData @relation(fields: [userDataId], references: [id], onDelete: Cascade)
  address   Address  @relation(fields: [addressId], references: [id])
}

model Banner {
  id        String    @id @default(uuid())
  title     String
  subtitle  String?
  imageUrl  String?
  active    Boolean   @default(true)
  order     Int       @default(0)
  buttons   Json      @default("[]")
  startDate DateTime?
  endDate   DateTime?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ContactMessage {
  id        String    @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  read      Boolean   @default(false)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model UserRelation {
  id        String    @id @default(uuid())
  sourceId  String
  targetId  String
  label     String?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  source    UserData @relation("RelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target    UserData @relation("RelationTarget", fields: [targetId], references: [id], onDelete: Cascade)
}
